PORT=3001
NODE_ENV=development        # 'production' enables Secure cookies + strict CORS

# ── CORS ─────────────────────────────────────────────────────────────────────
# Required in production. Set to your frontend origin (no trailing slash).
# CORS_ORIGIN=https://qa.miempresa.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── AI (Hybrid mode) ─────────────────────────────────────────────────────────
# Optional. Without this key only "local_only" analysis mode works.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # or claude-sonnet-4-6, claude-opus-4-7

# ── Email (Password reset) ───────────────────────────────────────────────────
# Required in production so users can reset their passwords.
# Any SMTP provider works: Gmail, SendGrid, Brevo, Mailgun, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=app-password-here          # Gmail: generate an App Password
# SMTP_FROM="QA Assist <no-reply@miempresa.com>"
# APP_URL=https://qa.miempresa.com     # used to build the reset link in emails

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
# BACKUP_CRON=0 3 * * *               # cron schedule (default: 03:00 daily)
# CACHE_TTL_DAYS=7                    # days before purging old AI cache entries
# BACKUP_S3_BUCKET=my-bucket          # push to S3 (delete local copy after)
#   requires: npm install @aws-sdk/client-s3
#   AWS creds: AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com           # comma-separated emails with admin access

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                        # trace|debug|info|warn|error|fatal
# LOG_FILE=/var/log/qa-assist/app     # file output (requires: npm install pino-roll)
